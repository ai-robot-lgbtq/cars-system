# Application
APP_ENV=development
APP_PORT=8080

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=cars
DB_PASSWORD=cars_pass
DB_NAME=cars_db
DB_SSLMODE=disable

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=dev-secret-change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# WebSocket
WS_BROKER=memory

# Payment
PAYMENT_GATEWAY=local

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost/api/v1/ws